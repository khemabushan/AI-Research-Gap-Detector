# --- OpenAI / LangChain ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Semantic Scholar ---
# Optional but strongly recommended: unauthenticated requests are heavily rate-limited.
SEMANTIC_SCHOLAR_API_KEY=

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_URL=sqlite:///./data/app.db

# --- Vector store ---
FAISS_INDEX_DIR=./data/faiss_indexes
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Collection limits ---
MAX_PAPERS_PER_SOURCE=20
ARXIV_REQUEST_DELAY_SECONDS=3.0
